# Copy to .env in this directory for local runs: cp .env.example .env
# Docker Compose (dev) can load api/.env via env_file — set JWT_SECRET to match web.

PORT=8080
DATABASE_URL=postgresql://fintrack:fintrack@localhost:5432/fintrack

# Required when DATABASE_URL is set (≥16 characters). Same value as web JWT_SECRET for sessions.
JWT_SECRET=change-me-at-least-16-chars

# Comma-separated browser origins for credentialed CORS (when the Next app calls the API directly).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional
# SKIP_MIGRATIONS=false
# COOKIE_SECURE=false
