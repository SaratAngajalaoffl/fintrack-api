# HTTP listen port (numeric only — the app prefixes ":" automatically)
PORT=8080

# Required for normal startup (migrations run before the HTTP server accepts traffic).
DATABASE_URL=postgresql://fintrack:fintrack@localhost:5432/fintrack

# Same value as web/.env JWT_SECRET (middleware). Min 16 characters.
# JWT_SECRET=

# Session cookie Secure flag: set true or 1 for HTTPS-only cookies (production).
# COOKIE_SECURE=false

# Directory containing ordered *.sql files (same filenames as schema_migrations.version).
# From repo root after `cd api`, the default in code resolves to ../migrations.
# In Docker, set to /migrations with that path bind-mounted from the repository.
MIGRATIONS_PATH=../migrations

# Set to 1 or true to skip migrations (local debugging without a database).
# SKIP_MIGRATIONS=false

# Comma-separated **Origin** values allowed for credentialed CORS (browser `fetch` to this API from Next on another port/host). If unset, defaults to `http://localhost:3000` and `http://127.0.0.1:3000`.
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
